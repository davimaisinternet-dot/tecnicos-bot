# Worker
PORT=3100

# Grupo WhatsApp alvo (chat_id completo, ex: 5586XXXXXXX-XXXXXXXXXX@g.us)
CHAT_ID=SEU_GRUPO_ID_AQUI@g.us

# WPPConnect (reusa uma sessao existente ou cria nova)
WPP_HOST=http://wppconnect:21465
WPP_SESSION=rifa-bot
WPP_SECRET=MUDE_ESSE_SECRET

# Gemini API (gratis em https://aistudio.google.com/apikey)
GEMINI_KEY=SUA_KEY_AQUI
GEMINI_MODEL=gemini-2.5-flash-lite

# Gesprov / ERP (opcional, deixe vazio se nao usar)
GESPROV_URL=

# Responder no grupo apos cada registro (true/false)
REPLY_ON_GROUP=true

# Postgres (reusa do rifa-bot ou dedicado)
PGHOST=postgres
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=rifa_bot
